{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:bump": "uv version ${version} && git add pyproject.toml uv.lock"
  }
}
